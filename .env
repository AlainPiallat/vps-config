# =============================================================================
# CONFIGURATION VARIABLES - MODIFY THESE VALUES
# =============================================================================

# Domain configuration
DOMAIN=votredomaine.fr

# SSH Configuration
SSH_PORT=2222
SSH_USER=your-username
SSH_PUBLIC_KEY=ssh-rsa AAAA... your-public-key-here

# Cloudflare DNS (for SSL certificates)
CLOUDFLARE_EMAIL=votre-email@domain.com
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Grafana configuration
GRAFANA_PASSWORD=ChangeThisStrongPassword123!

# Vaultwarden configuration
VAULTWARDEN_ADMIN_TOKEN=generate-secure-token-here

# Email configuration
SMTP_PASSWORD=your-email-password

# Backup configuration
RESTIC_PASSWORD=YourStrongBackupPassword123!

# Notification URL (optional - for backup notifications)
NOTIFICATION_URL=

# Timezone
TZ=Europe/Paris

# Nextcloud AIO Configuration
NEXTCLOUD_DATADIR=/opt/nextcloud-data
APACHE_PORT=11000